import { Palette } from "./palette.slint";
import { Card } from "./card.slint";
import { SectionHeader } from "./section-header.slint";
import { AppRow } from "./app-row.slint";
import { SwitchRow } from "./switch-row.slint";
import { TimeLog, SwitchHistory } from "./types.slint";

component ViewToggleButton inherits Rectangle {
    in property <string> label;
    in property <color> base-color;
    in property <color> hover-color;
    in property <color> pressed-color;
    
    in property <color> normal-bg-color;
    in property <color> hover-bg-color;
    in property <color> pressed-bg-color;
    
    in property <color> normal-border-color;
    in property <color> hover-border-color;
    in property <color> pressed-border-color;

    callback clicked;

    width: 115px * Palette.scale;
    height: 24px * Palette.scale;
    border-radius: 5px * Palette.scale;
    border-width: 1px * Palette.scale;

    animate background { duration: 100ms; }
    animate border-color { duration: 100ms; }

    states [
        pressed when ta.pressed: {
            background: pressed-bg-color;
            border-color: pressed-border-color;
        }
        hovered when ta.has-hover: {
            background: hover-bg-color;
            border-color: hover-border-color;
        }
        normal when !ta.has-hover: {
            background: normal-bg-color;
            border-color: normal-border-color;
        }
    ]

    Text {
        text: label;
        font-size: 10px * Palette.scale;
        font-weight: 600;
        color: ta.pressed ? pressed-color : ta.has-hover ? hover-color : base-color;
        horizontal-alignment: center;
        vertical-alignment: center;
        animate color { duration: 100ms; }
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

export component DataView {
    in property <int>             trackedTime_S;
    in property <[TimeLog]>       timePerApp_S;
    in property <[SwitchHistory]> switchHistory_S;

    callback switch-to-live-clicked;

    VerticalLayout {
        padding: 12px * Palette.scale;
        padding-top: 0px;
        spacing: 10px * Palette.scale;

        HorizontalLayout {
            vertical-stretch: 0;

            SectionHeader {
                label: "TIME PER APP";
                horizontal-stretch: 1;
            }

            HorizontalLayout {
                spacing: 4px * Palette.scale;
                alignment: end;

                ViewToggleButton {
                    label: "Switch to Live View";
                    base-color: #38bdf8;
                    hover-color: #7dd3fc;
                    pressed-color: #bae6fd;
                    normal-bg-color: #38bdf812;
                    hover-bg-color: #38bdf825;
                    pressed-bg-color: #38bdf835;
                    normal-border-color: #38bdf835;
                    hover-border-color: #38bdf860;
                    pressed-border-color: #38bdf880;
                    clicked => { root.switch-to-live-clicked(); }
                }
            }
        }

        Card {
            vertical-stretch: 1;
            Flickable {
                width: 100%;
                height: 100%;
                interactive: true;
                viewport-height: appContent.preferred-height;

                appContent := VerticalLayout {
                    width: 100%;
                    for entry[i] in timePerApp_S: AppRow {
                        app-name: entry.name;
                        ratio: trackedTime_S > 0 ? (entry.duration_i * 1.0) / (trackedTime_S * 1.0) : 0.0;
                        duration: entry.duration + " (" + Math.round(self.ratio * 100) + "%" + ")";
                        is-even: mod(i, 2) == 0;
                        row-index: i;
                        bar-color: Colors.hsv(mod(entry.name.character-count * 47, 360), 0.75, 0.85);
                    }
                }
            }
        }

        SectionHeader { label: "SWITCH HISTORY"; }

        Card {
            vertical-stretch: 1;

            Flickable {
                width: 100%;
                height: 100%;
                interactive: true;
                viewport-height: swContent.preferred-height;

                swContent := VerticalLayout {
                    width: 100%;
                    for entry[i] in switchHistory_S: SwitchRow {
                        from-window: entry.fromWindow;
                        to-window:   entry.toWindow;
                        timestamp:   entry.maxTimeStamp;
                        is-even: mod(i, 2) == 0;
                    }
                }
            }
        }
    }
}