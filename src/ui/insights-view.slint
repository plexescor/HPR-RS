import { Card } from "./card.slint";
import { SectionHeader } from "./section-header.slint";
import { Palette } from "./palette.slint";

export component InsightsView {
    in property <string> mostUsedApp_S;
    in property <string> totalTrackedTime_S;
    in property <string> totalSwitches_S;
    in property <string> mostSwitchedFrom_S;
    in property <string> mostSwitchedTo_S;
    in property <string> longestFocus_S;
    in property <string> peakHour_S;

    // Advanced cross-day insights
    in property <string> escapePattern_S;
    in property <string> returnRate_S;
    in property <string> avgFocusSession_S;
    in property <string> mostDistractedDay_S;
    in property <string> productiveDays_S;
    in property <string> screenTimeVsAvg_S;
    in property <string> focusDipHour_S;
    in property <string> deepWorkBeforeNoon_S;
    in property <string> weekendVsWeekday_S;

    callback load-insights;

    VerticalLayout {
        padding: 12px * Palette.scale;
        padding-top: 0px;
        spacing: 10px * Palette.scale;

        HorizontalLayout {
            alignment: space-between;
            vertical-stretch: 0;
            padding-top: 4px * Palette.scale;

            SectionHeader { label: "INSIGHTS"; }

            refreshBtn := Rectangle {
                width: 72px * Palette.scale;
                height: 26px * Palette.scale;
                border-radius: 6px * Palette.scale;
                border-width: 1px * Palette.scale;

                animate background { duration: 100ms; }
                animate border-color { duration: 100ms; }

                ta-refresh := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.load-insights(); }
                }

                states [
                    pressed when ta-refresh.pressed: {
                        background: #34d39935;
                        border-color: #34d39980;
                    }
                    hovered when ta-refresh.has-hover: {
                        background: #34d39925;
                        border-color: #34d39960;
                    }
                    normal when !ta-refresh.has-hover: {
                        background: #34d39912;
                        border-color: #34d39935;
                    }
                ]

                Text {
                    text: "REFRESH";
                    font-size: 8px * Palette.scale;
                    font-weight: 700;
                    letter-spacing: 2px * Palette.scale;
                    color: ta-refresh.pressed ? #a7f3d0 : ta-refresh.has-hover ? #6ee7b7 : #34d399;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    animate color { duration: 100ms; }
                }
            }
        }

        Flickable {
            vertical-stretch: 1;
            interactive: true;
            viewport-height: insightContent.preferred-height;

            insightContent := VerticalLayout {
                width: 100%;
                spacing: 8px * Palette.scale;

                // â”€â”€ TODAY â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
                Text {
                    text: "TODAY";
                    font-size: 8px * Palette.scale;
                    font-weight: 700;
                    letter-spacing: 3px * Palette.scale;
                    color: Palette.text-label;
                    x: 4px * Palette.scale;
                }

                Card {
                    height: 64px * Palette.scale;
                    HorizontalLayout {
                        padding: 16px * Palette.scale;
                        alignment: space-between;
                        Text {
                            text: "MOST USED APP";
                            font-size: 9px * Palette.scale;
                            font-weight: 700;
                            letter-spacing: 2.5px * Palette.scale;
                            color: Palette.text-muted;
                            vertical-alignment: center;
                        }
                        Text {
                            text: mostUsedApp_S;
                            font-size: 15px * Palette.scale;
                            font-weight: 600;
                            color: #a3e635;
                            vertical-alignment: center;
                        }
                    }
                }

                Card {
                    height: 64px * Palette.scale;
                    HorizontalLayout {
                        padding: 16px * Palette.scale;
                        alignment: space-between;
                        Text {
                            text: "TOTAL TRACKED TIME";
                            font-size: 9px * Palette.scale;
                            font-weight: 700;
                            letter-spacing: 2.5px * Palette.scale;
                            color: Palette.text-muted;
                            vertical-alignment: center;
                        }
                        Text {
                            text: totalTrackedTime_S;
                            font-size: 15px * Palette.scale;
                            font-weight: 600;
                            color: #38bdf8;
                            vertical-alignment: center;
                        }
                    }
                }

                Card {
                    height: 64px * Palette.scale;
                    HorizontalLayout {
                        padding: 16px * Palette.scale;
                        alignment: space-between;
                        Text {
                            text: "TOTAL APP SWITCHES";
                            font-size: 9px * Palette.scale;
                            font-weight: 700;
                            letter-spacing: 2.5px * Palette.scale;
                            color: Palette.text-muted;
                            vertical-alignment: center;
                        }
                        Text {
                            text: totalSwitches_S;
                            font-size: 15px * Palette.scale;
                            font-weight: 600;
                            color: #f472b6;
                            vertical-alignment: center;
                        }
                    }
                }

                Card {
                    height: 64px * Palette.scale;
                    HorizontalLayout {
                        padding: 16px * Palette.scale;
                        alignment: space-between;
                        Text {
                            text: "MOST SWITCHED FROM";
                            font-size: 9px * Palette.scale;
                            font-weight: 700;
                            letter-spacing: 2.5px * Palette.scale;
                            color: Palette.text-muted;
                            vertical-alignment: center;
                        }
                        Text {
                            text: mostSwitchedFrom_S;
                            font-size: 15px * Palette.scale;
                            font-weight: 600;
                            color: #fb923c;
                            vertical-alignment: center;
                        }
                    }
                }

                Card {
                    height: 64px * Palette.scale;
                    HorizontalLayout {
                        padding: 16px * Palette.scale;
                        alignment: space-between;
                        Text {
                            text: "MOST SWITCHED TO";
                            font-size: 9px * Palette.scale;
                            font-weight: 700;
                            letter-spacing: 2.5px * Palette.scale;
                            color: Palette.text-muted;
                            vertical-alignment: center;
                        }
                        Text {
                            text: mostSwitchedTo_S;
                            font-size: 15px * Palette.scale;
                            font-weight: 600;
                            color: #fb923c;
                            vertical-alignment: center;
                        }
                    }
                }

                Card {
                    height: 64px * Palette.scale;
                    HorizontalLayout {
                        padding: 16px * Palette.scale;
                        alignment: space-between;
                        Text {
                            text: "LONGEST FOCUS SESSION";
                            font-size: 9px * Palette.scale;
                            font-weight: 700;
                            letter-spacing: 2.5px * Palette.scale;
                            color: Palette.text-muted;
                            vertical-alignment: center;
                        }
                        Text {
                            text: longestFocus_S;
                            font-size: 15px * Palette.scale;
                            font-weight: 600;
                            color: #34d399;
                            vertical-alignment: center;
                        }
                    }
                }

                Card {
                    height: 64px * Palette.scale;
                    HorizontalLayout {
                        padding: 16px * Palette.scale;
                        alignment: space-between;
                        Text {
                            text: "PEAK PRODUCTIVE HOUR";
                            font-size: 9px * Palette.scale;
                            font-weight: 700;
                            letter-spacing: 2.5px * Palette.scale;
                            color: Palette.text-muted;
                            vertical-alignment: center;
                        }
                        Text {
                            text: peakHour_S;
                            font-size: 15px * Palette.scale;
                            font-weight: 600;
                            color: #c084fc;
                            vertical-alignment: center;
                        }
                    }
                }

                // â”€â”€ PATTERNS (multi-day) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
                Rectangle { height: 8px * Palette.scale; }

                Text {
                    text: "PATTERNS";
                    font-size: 8px * Palette.scale;
                    font-weight: 700;
                    letter-spacing: 3px * Palette.scale;
                    color: Palette.text-label;
                    x: 4px * Palette.scale;
                }

                // Full-width natural-language cards
                Card {
                    height: 64px * Palette.scale;
                    VerticalLayout {
                        padding-left: 16px * Palette.scale;
                        padding-right: 16px * Palette.scale;
                        alignment: center;
                        spacing: 2px * Palette.scale;
                        Text {
                            text: "ESCAPE PATTERN";
                            font-size: 9px * Palette.scale;
                            font-weight: 700;
                            letter-spacing: 2.5px * Palette.scale;
                            color: Palette.text-muted;
                        }
                        Text {
                            text: escapePattern_S;
                            font-size: 14px * Palette.scale;
                            font-weight: 700;
                            color: #f472b6;
                            wrap: word-wrap;
                        }
                    }
                }

                Card {
                    height: 64px * Palette.scale;
                    VerticalLayout {
                        padding-left: 16px * Palette.scale;
                        padding-right: 16px * Palette.scale;
                        alignment: center;
                        spacing: 2px * Palette.scale;
                        Text {
                            text: "RETURN RATE";
                            font-size: 9px * Palette.scale;
                            font-weight: 700;
                            letter-spacing: 2.5px * Palette.scale;
                            color: Palette.text-muted;
                        }
                        Text {
                            text: returnRate_S;
                            font-size: 14px * Palette.scale;
                            font-weight: 700;
                            color: #fb923c;
                            wrap: word-wrap;
                        }
                    }
                }

                Card {
                    height: 64px * Palette.scale;
                    VerticalLayout {
                        padding-left: 16px * Palette.scale;
                        padding-right: 16px * Palette.scale;
                        alignment: center;
                        spacing: 2px * Palette.scale;
                        Text {
                            text: "AVERAGE FOCUS SESSION";
                            font-size: 9px * Palette.scale;
                            font-weight: 700;
                            letter-spacing: 2.5px * Palette.scale;
                            color: Palette.text-muted;
                        }
                        Text {
                            text: avgFocusSession_S;
                            font-size: 14px * Palette.scale;
                            font-weight: 700;
                            color: #34d399;
                            wrap: word-wrap;
                        }
                    }
                }

                Card {
                    height: 64px * Palette.scale;
                    VerticalLayout {
                        padding-left: 16px * Palette.scale;
                        padding-right: 16px * Palette.scale;
                        alignment: center;
                        spacing: 2px * Palette.scale;
                        Text {
                            text: "MOST DISTRACTED DAY";
                            font-size: 9px * Palette.scale;
                            font-weight: 700;
                            letter-spacing: 2.5px * Palette.scale;
                            color: Palette.text-muted;
                        }
                        Text {
                            text: mostDistractedDay_S;
                            font-size: 14px * Palette.scale;
                            font-weight: 700;
                            color: #f87171;
                            wrap: word-wrap;
                        }
                    }
                }

                Card {
                    height: 64px * Palette.scale;
                    VerticalLayout {
                        padding-left: 16px * Palette.scale;
                        padding-right: 16px * Palette.scale;
                        alignment: center;
                        spacing: 2px * Palette.scale;
                        Text {
                            text: "PRODUCTIVE DAYS";
                            font-size: 9px * Palette.scale;
                            font-weight: 700;
                            letter-spacing: 2.5px * Palette.scale;
                            color: Palette.text-muted;
                        }
                        Text {
                            text: productiveDays_S;
                            font-size: 14px * Palette.scale;
                            font-weight: 700;
                            color: #a3e635;
                            wrap: word-wrap;
                        }
                    }
                }

                Card {
                    height: 64px * Palette.scale;
                    VerticalLayout {
                        padding-left: 16px * Palette.scale;
                        padding-right: 16px * Palette.scale;
                        alignment: center;
                        spacing: 2px * Palette.scale;
                        Text {
                            text: "SCREEN TIME VS AVERAGE";
                            font-size: 9px * Palette.scale;
                            font-weight: 700;
                            letter-spacing: 2.5px * Palette.scale;
                            color: Palette.text-muted;
                        }
                        Text {
                            text: screenTimeVsAvg_S;
                            font-size: 14px * Palette.scale;
                            font-weight: 700;
                            color: #38bdf8;
                            wrap: word-wrap;
                        }
                    }
                }

                Card {
                    height: 64px * Palette.scale;
                    VerticalLayout {
                        padding-left: 16px * Palette.scale;
                        padding-right: 16px * Palette.scale;
                        alignment: center;
                        spacing: 2px * Palette.scale;
                        Text {
                            text: "DAILY FOCUS DIP";
                            font-size: 9px * Palette.scale;
                            font-weight: 700;
                            letter-spacing: 2.5px * Palette.scale;
                            color: Palette.text-muted;
                        }
                        Text {
                            text: focusDipHour_S;
                            font-size: 14px * Palette.scale;
                            font-weight: 700;
                            color: #fbbf24;
                            wrap: word-wrap;
                        }
                    }
                }

                Card {
                    height: 64px * Palette.scale;
                    VerticalLayout {
                        padding-left: 16px * Palette.scale;
                        padding-right: 16px * Palette.scale;
                        alignment: center;
                        spacing: 2px * Palette.scale;
                        Text {
                            text: "PEAK DEEP WORK WINDOW";
                            font-size: 9px * Palette.scale;
                            font-weight: 700;
                            letter-spacing: 2.5px * Palette.scale;
                            color: Palette.text-muted;
                        }
                        Text {
                            text: deepWorkBeforeNoon_S;
                            font-size: 14px * Palette.scale;
                            font-weight: 700;
                            color: #c084fc;
                            wrap: word-wrap;
                        }
                    }
                }

                Card {
                    height: 64px * Palette.scale;
                    VerticalLayout {
                        padding-left: 16px * Palette.scale;
                        padding-right: 16px * Palette.scale;
                        alignment: center;
                        spacing: 2px * Palette.scale;
                        Text {
                            text: "WEEKEND VS WEEKDAY";
                            font-size: 9px * Palette.scale;
                            font-weight: 700;
                            letter-spacing: 2.5px * Palette.scale;
                            color: Palette.text-muted;
                        }
                        Text {
                            text: weekendVsWeekday_S;
                            font-size: 14px * Palette.scale;
                            font-weight: 700;
                            color: #818cf8;
                            wrap: word-wrap;
                        }
                    }
                }
            }
