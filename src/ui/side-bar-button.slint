import { Palette } from "./palette.slint";

// ── Sidebar button with tooltip ──────────────────────────────────────────────
export component SidebarButton inherits Rectangle {
    in property <image> icon;
    in property <image> icon-light;
    in property <string> tip;
    callback clicked;

    height: 35px * Palette.scale;
    width: 38px * Palette.scale;
    border-radius: 6px * Palette.scale;
    background: ta.has-hover ? Palette.sidebar-btn-bg-hover : Palette.sidebar-btn-bg;
    border-width: 1px * Palette.scale;
    border-color: ta.has-hover ? Palette.sidebar-btn-border-hover : Palette.sidebar-btn-border;
    animate background { duration: 100ms; easing: ease-out; }

    Image {
        source: Palette.is-dark ? icon : icon-light;
        width: 20px * Palette.scale; 
        height: 20px * Palette.scale;
        horizontal-alignment: center;
        vertical-alignment: center;
        image-fit: contain;
    }

    // Tooltip bubble — floats to the right, z:100 paints over sibling content
    Rectangle {
        z: 100;
        opacity: ta.has-hover ? 1.0 : 0.0;
        animate opacity { duration: 175ms; delay: 500ms; easing: ease-out; }

        x: parent.width + 8px * Palette.scale;
        y: (parent.height - self.height) / 2;
        height: tip-text.preferred-height + 8px * Palette.scale;
        width: tip-text.preferred-width + 14px * Palette.scale;
        border-radius: 4px * Palette.scale;
        background: Palette.tooltip-bg;
        border-width: 1px * Palette.scale;
        border-color: Palette.tooltip-border;

        tip-text := Text {
            x: 7px * Palette.scale;
            y: 4px * Palette.scale;
            text: tip;
            color: Palette.text-secondary;
            font-size: 11px * Palette.scale;
            font-weight: 500;
        }
    }

    ta := TouchArea {
        clicked => { root.clicked(); }
    }
}
