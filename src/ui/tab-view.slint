import { Card } from "./card.slint";
import { SectionHeader } from "./section-header.slint";
import { TimeLog_Tab } from "./types.slint";
import { Palette } from "./palette.slint";

component TabRow inherits Rectangle {
    in property <string> tab-title;
    in property <string> duration;
    in property <float>  ratio;
    in property <bool>   is-even;
    in property <int>    row-index;
    in property <color>  bar-color;

    height: 48px * Palette.scale;
    border-radius: 5px * Palette.scale;
    clip: true;

    background: ta.has-hover ? Palette.row-bg-hover : (is-even ? Palette.row-bg-even : transparent);
    animate background { duration: 100ms; easing: ease-out; }

    HorizontalLayout {
        padding-left: 16px * Palette.scale;
        padding-right: 14px * Palette.scale;
        spacing: 12px * Palette.scale;

        Text {
            text: (row-index + 1) + ".";
            color: Palette.row-number;
            font-size: 10px * Palette.scale;
            font-weight: 600;
            vertical-alignment: center;
            width: 18px * Palette.scale;
        }

        Rectangle {
            width: 3px * Palette.scale;
            height: 20px * Palette.scale;
            border-radius: 2px * Palette.scale;
            background: ta.has-hover ? bar-color : bar-color.mix(#00000000, 0.45);
            animate background { duration: 100ms; }
            y: (parent.height - self.height) / 2;
        }

        VerticalLayout {
            padding-top: 8px * Palette.scale;
            padding-bottom: 8px * Palette.scale;
            spacing: 5px * Palette.scale;
            horizontal-stretch: 1;

            HorizontalLayout {
                Text {
                    text: tab-title;
                    color: ta.has-hover ? Palette.text-primary : Palette.text-secondary;
                    font-size: 12px * Palette.scale;
                    vertical-alignment: center;
                    animate color { duration: 100ms; }
                    overflow: elide;
                    horizontal-stretch: 1;
                }

                Text {
                    text: duration;
                    color: ta.has-hover ? bar-color : bar-color.mix(#00000000, 0.45);
                    font-size: 10px * Palette.scale;
                    font-weight: 600;
                    vertical-alignment: center;
                    animate color { duration: 100ms; }
                }
            }

            Rectangle {
                height: 4px * Palette.scale;
                border-radius: 2px * Palette.scale;
                background: Palette.bar-track;

                Rectangle {
                    x: 0;
                    height: 4px * Palette.scale;
                    border-radius: 2px * Palette.scale;
                    width: parent.width * ratio;
                    background: ta.has-hover
                        ? @linear-gradient(90deg, bar-color 0%, bar-color.mix(#ffffff, 0.3) 100%)
                        : @linear-gradient(90deg, bar-color.mix(#00000000, 0.45) 0%, bar-color.mix(#ffffff, 0.15).mix(#00000000, 0.45) 100%);
                    animate background { duration: 100ms; }
                    animate width { duration: 400ms; easing: ease-out; }
                }
            }
        }
    }
    ta := TouchArea {}
}

component ViewToggleButton inherits Rectangle {
    in property <string> label;
    in property <color> base-color;
    in property <color> hover-color;
    in property <color> pressed-color;
    
    in property <color> normal-bg-color;
    in property <color> hover-bg-color;
    in property <color> pressed-bg-color;
    
    in property <color> normal-border-color;
    in property <color> hover-border-color;
    in property <color> pressed-border-color;

    callback clicked;

    width: 60px * Palette.scale;
    height: 24px * Palette.scale;
    border-radius: 5px * Palette.scale;
    border-width: 1px * Palette.scale;

    animate background { duration: 100ms; }
    animate border-color { duration: 100ms; }

    states [
        pressed when ta.pressed: {
            background: pressed-bg-color;
            border-color: pressed-border-color;
        }
        hovered when ta.has-hover: {
            background: hover-bg-color;
            border-color: hover-border-color;
        }
        normal when !ta.has-hover: {
            background: normal-bg-color;
            border-color: normal-border-color;
        }
    ]

    Text {
        text: label;
        font-size: 10px * Palette.scale;
        font-weight: 600;
        color: ta.pressed ? pressed-color : ta.has-hover ? hover-color : base-color;
        horizontal-alignment: center;
        vertical-alignment: center;
        animate color { duration: 100ms; }
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

export component TabView {
    in property <[TimeLog_Tab]> timePerTab_S;
    in property <int>           trackedTime_S;
    callback per-tab-clicked;
    callback per-site-clicked;

    VerticalLayout {
        padding: 12px * Palette.scale;
        padding-top: 0px;
        spacing: 10px * Palette.scale;
        height: 100%;

        HorizontalLayout {
            vertical-stretch: 0;

            SectionHeader {
                label: "TIME PER TAB";
                horizontal-stretch: 1;
            }

            HorizontalLayout {
                spacing: 4px * Palette.scale;
                alignment: end;

                ViewToggleButton {
                    label: "Per-Tab";
                    base-color: #c084fc;
                    hover-color: #d8b4fe;
                    pressed-color: #e9d5ff;
                    normal-bg-color: #c084fc12;
                    hover-bg-color: #c084fc25;
                    pressed-bg-color: #c084fc35;
                    normal-border-color: #c084fc35;
                    hover-border-color: #c084fc60;
                    pressed-border-color: #c084fc80;
                    clicked => { root.per-tab-clicked(); }
                }

                ViewToggleButton {
                    label: "Per-Site";
                    base-color: #a3e635;
                    hover-color: #bef264;
                    pressed-color: #d9f99d;
                    normal-bg-color: #a3e63512;
                    hover-bg-color: #a3e63525;
                    pressed-bg-color: #a3e63535;
                    normal-border-color: #a3e63535;
                    hover-border-color: #a3e63560;
                    pressed-border-color: #a3e63580;
                    clicked => { root.per-site-clicked(); }
                }
            }
        }

        Card {
            vertical-stretch: 1;

            Flickable {
                width: 100%;
                height: 100%;
                interactive: true;
                viewport-height: tabContent.preferred-height;

                tabContent := VerticalLayout {
                    width: 100%;
                    for entry[i] in timePerTab_S: TabRow {
                        tab-title: entry.name;
                        ratio: trackedTime_S > 0
                            ? (entry.duration_i * 1.0) / (trackedTime_S * 1.0)
                            : 0.0;
                        duration: entry.duration
                            + " (" + Math.round(self.ratio * 100) + "%" + ")";
                        is-even:   mod(i, 2) == 0;
                        row-index: i;
                        bar-color: Colors.hsv(
                            mod(entry.name.character-count * 61, 360),
                            0.70, 0.88
                        );
                    }
                }
            }
        }
    }
}