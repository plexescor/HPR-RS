import { Palette } from "./palette.slint";

// ── Switch row ───────────────────────────────────────────────────────────────
export component SwitchRow inherits Rectangle {
    in property <string> from-window;
    in property <string> to-window;
    in property <string> timestamp;
    in property <bool>   is-even;

    height: 48px * Palette.scale;
    border-radius: 5px * Palette.scale;
    clip: true;

    background: ta.has-hover ? Palette.row-bg-hover : (is-even ? Palette.row-bg-even : transparent);
    animate background { duration: 100ms; easing: ease-out; }

    Rectangle {
        x: 0;
        width: 2px * Palette.scale;
        height: parent.height;
        background: ta.has-hover ? #818cf8cc : #00000000;
        animate background { duration: 120ms; easing: ease-out; }
    }

    VerticalLayout {
        padding-left: 16px * Palette.scale;
        padding-right: 12px * Palette.scale;
        padding-top: 8px * Palette.scale;
        padding-bottom: 8px * Palette.scale;
        spacing: 3px * Palette.scale;

        HorizontalLayout {
            spacing: 5px * Palette.scale;
            alignment: start;

            Text {
                text: from-window;
                color: #fb7185;
                font-size: 11px * Palette.scale;
                font-weight: 600;
                vertical-alignment: center;
                overflow: elide;
                max-width: 120px * Palette.scale;
            }

            Text {
                text: "→";
                color: Palette.text-muted;
                font-size: 11px * Palette.scale;
                vertical-alignment: center;
            }

            Text {
                text: to-window;
                color: #34d399;
                font-size: 11px * Palette.scale;
                font-weight: 600;
                vertical-alignment: center;
                overflow: elide;
                max-width: 120px * Palette.scale;
            }
        }

        Text {
            text: timestamp;
            color: Palette.text-dim;
            font-size: 10px * Palette.scale;
            letter-spacing: 0.3px * Palette.scale;
            vertical-alignment: center;
        }
    }

    ta := TouchArea {}
}
